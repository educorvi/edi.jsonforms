<div class="p-3 mb-4 bg-body-tertiary rounded-3">
  <div class="container-fluid py-5">
    <h2 class="display-5 fw-bold"
        i18n:translate=""
    >Developer Area</h2>
    <div class="accordion"
         id="accordionDeveloper"
    >
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed"
                  aria-controls="collapseSchema"
                  aria-expanded="true"
                  type="button"
                  data-bs-target="#collapseSchema"
                  data-bs-toggle="collapse"
                  i18n:translate=""
          >
                  Current JSON-Schema (Draft)
          </button>
        </h2>
        <div class="accordion-collapse collapse"
             id="collapseSchema"
             data-bs-parent="#accordionDeveloper"
        >
          <div class="accordion-body">
            <pre class="rounded"><code class="language-json theme-atom-one-dark"
                    tal:content="view/get_json_schema"
              ></code></pre>
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed"
                  aria-controls="collapseUI"
                  aria-expanded="true"
                  type="button"
                  data-bs-target="#collapseUI"
                  data-bs-toggle="collapse"
                  i18n:translate=""
          >
                  Current UI-Schema (Draft)
          </button>
        </h2>
        <div class="accordion-collapse collapse"
             id="collapseUI"
             data-bs-parent="#accordionDeveloper"
        >
          <div class="accordion-body">
            <pre class="rounded"><code class="language-json theme-atom-one-dark"
                    tal:content="view/get_ui_schema"
              ></code></pre>
          </div>
        </div>
      </div>
    </div>
    <div class="row mt-5"
         tal:define="
           versions python: view.get_versions();
         "
         tal:condition="versions"
    >
      <div class="col-12">
        <h3 i18n:translate="">Stable-Versions</h3>
        <div class="accordion"
             tal:repeat="version python: versions"
             tal:attributes="
               id python: 'accordionVersion' + str(version['version_id']);
             "
        >
          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed"
                      aria-expanded="true"
                      type="button"
                      data-bs-toggle="collapse"
                      tal:attributes="
                        data-bs-target python: '#collapseVersion' + str(version['version_id']);
                        aria-controls python: 'collapseVersion' + str(version['version_id']);
                      "
                      i18n:translate=""
              >
                <span tal:content="python: str(version['version_id']) + ': ' + str(version['comment'])"></span>
              </button>
            </h2>
            <div class="accordion-collapse collapse"
                 tal:attributes="
                   id python: 'collapseVersion' + str(version['version_id']);
                   data-bs-parent python: '#accordionVersion' + str(version['version_id']);
                 "
            >
              <div class="accordion-body">
                <ul>
                  <li>
                    <a tal:attributes="
                         href python: version['json_schema_url'];
                       ">[JSON-Schema]</a>
                  </li>
                  <li>
                    <a tal:attributes="
                         href python: version['ui_schema_url'];
                       ">[UI-Schema]</a>
                  </li>
                  <li tal:condition="python: version['forks']">
                    <a tal:attributes="
                         href python: version['forks_schema_url'];
                       "
                       i18n:translate=""
                    >Forks</a>
                    <ul>
                      <li tal:repeat="fork python: version['forks']">
                        <span tal:content="python: fork['name']"></span>
                        <ul>
                          <li>
                            <a tal:attributes="
                                 href python: fork['json_schema_url'];
                               ">[JSON-Schema]</a>
                          </li>
                          <li>
                            <a tal:attributes="
                                 href python: fork['ui_schema_url'];
                               ">[UI-Schema]</a>
                          </li>
                        </ul>
                      </li>
                    </ul>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    hljs.addPlugin(new CopyButtonPlugin());
    hljs.highlightAll();
  });
</script>
