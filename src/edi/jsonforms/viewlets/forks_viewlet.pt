<div class="p-3 mb-4 bg-body-tertiary rounded-3"
     tal:condition="python: view.forks_available()"
>
  <div class="container-fluid py-5">
    <h2 class="display-5 fw-bold"
        i18n:translate=""
    >Information</h2>
    <div class="accordion"
         id="accordionForks"
    >
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed"
                  aria-controls="collapseForks"
                  aria-expanded="true"
                  type="button"
                  data-bs-target="#collapseForks"
                  data-bs-toggle="collapse"
                  i18n:translate=""
          >
                Available Forks
          </button>
        </h2>
        <div class="accordion-collapse collapse"
             id="collapseForks"
             data-bs-parent="#accordionForks"
        >
          <div class="accordion-body"
               tal:define="
                 forks python: view.create_available_fork_links();
               "
          >
            <div class="accordion"
                 tal:repeat="fork forks"
                 tal:attributes="
                   id python: 'accordionForksList' + str(fork['title']);
                 "
            >
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed"
                          aria-expanded="true"
                          type="button"
                          data-bs-toggle="collapse"
                          tal:content="python: fork['title']"
                          tal:attributes="
                            data-bs-target python: '#' + str(fork['title']);
                            aria-controls python: str(fork['title']);
                          "
                          i18n:translate=""
                  ></button>
                </h2>
                <div class="accordion-collapse collapse"
                     tal:attributes="
                       id python: str(fork['title']);
                       data-bs-parent python: '#accordionForksList' + str(fork['title']);
                     "
                >
                  <div class="accordion-body">
                    <a tal:content="python: fork['url']"
                       tal:attributes="
                         href python: fork['url'];
                       "
                    ></a>
                    <div class="table-responsive">
                      <table class="table"
                             tal:define="
                               table_data python: fork['data'];
                             "
                      >
                        <thead>
                          <th scope="col"
                              i18n:translate=""
                          >Path</th>
                          <th scope="col"
                              i18n:translate=""
                          >Attribute</th>
                          <th scope="col"
                              i18n:translate=""
                          >Value</th>
                        </thead>
                        <tbody>
                          <tr tal:repeat="row table_data">
                            <td tal:content="python: row[0]"></td>
                            <td tal:content="python: row[1]"></td>
                            <td tal:content="python: row[2]"></td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed"
                  aria-controls="collapseForksJson"
                  aria-expanded="true"
                  type="button"
                  data-bs-target="#collapseForksJson"
                  data-bs-toggle="collapse"
                  i18n:translate=""
          >
                        forks.json
          </button>
        </h2>
        <div class="accordion-collapse collapse"
             id="collapseForksJson"
             data-bs-parent="#accordionForks"
        >
          <div class="accordion-body"
               tal:define="
                 forksJson python: view.get_available_forks_string();
               "
          >
            <pre class="rounded"><code class="language-json theme-atom-one-dark"
                    tal:content="python: forksJson"
              ></code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
