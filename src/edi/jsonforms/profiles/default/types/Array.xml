<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Dexterity FTI"
        name="Array"
        i18n:domain="edi.jsonforms"
>

  <!-- Basic properties -->
  <property name="title"
            i18n:translate=""
  >Array</property>
  <property name="description"
            i18n:translate=""
  >An Array is a structured element that allows the repeated entry of related information by providing a template for a set of fields. It allows users to dynamically add additional sets of the same fields as needed. Arrays are particularly useful for capturing repetitive data entries, such as multiple contact or items in a list. An Array can be dependent from another field.</property>

  <property name="allow_discussion">False</property>
  <property name="factory">Array</property>
  <property name="icon_expr">string:collection</property>
  <property name="link_target" />

  <!-- Hierarchy control -->
  <property name="global_allow">False</property>
  <property name="filter_content_types">True</property>
  <property name="allowed_content_types">
    <!-- <element value="Fieldset" /> -->
    <element value="Reference" />
    <element value="Array" />
    <element value="Complex" />
    <element value="Field" />
    <element value="SelectionField" />
    <element value="UploadField" />
  </property>
  <!-- Schema, class and security -->
  <property name="add_permission">edi.jsonforms.AddArray</property>
  <property name="klass">edi.jsonforms.content.array.Array</property>
  <property name="model_file" />
  <property name="model_source" />
  <property name="schema">edi.jsonforms.content.array.IArray</property>

  <!-- Enabled behaviors -->
  <property name="behaviors"
            purge="false"
  >
    <!-- Details about all standard behaviors following can be read at
         https://docs.plone.org/external/plone.app.dexterity/docs/reference/standard-behaviours.html
    -->
    <element value="plone.namefromtitle" />
    <!-- <element value="plone.allowdiscussion"/> -->
    <!-- <element value="plone.excludefromnavigation"/> -->
    <element value="plone.shortname" />
    <!-- <element value="plone.ownership"/> -->
    <!-- <element value="plone.publication"/> -->
    <element value="plone.categorization" />
    <element value="plone.basic" />
    <element value="plone.app.referenceablebehavior.referenceable.IReferenceable" />
    <!--<element value="plone.leadimage"/>-->
    <!--<element value="plone.relateditems"/>-->
    <!--<element value="plone.richtext"/>-->
    <!--<element value="plone.tableofcontents"/>-->
    <!--<element value="plone.versioning" />-->
    <!--<element value="plone.translatable" />-->
    <!--<element value="plone.nextprevioustoggle" />-->
    <!--<element value="plone.nextpreviousenabled" />-->
    <!--<element value="plone.navigationroot" />-->
    <!--<element value="plone.selectablecontrainstypes" />-->
  </property>

  <!-- View information -->
  <property name="add_view_expr">string:${folder_url}/++add++Array</property>
  <property name="default_view">form-element-tools-view</property>
  <property name="default_view_fallback">False</property>
  <property name="immediate_view">form-element-tools-view</property>
  <property name="view_methods">
    <element value="form-element-view" />
    <element value="form-element-tools-view" />
  </property>

  <!-- Method aliases -->
  <alias from="(Default)"
         to="(dynamic view)"
  />
  <alias from="edit"
         to="@@edit"
  />
  <alias from="sharing"
         to="@@sharing"
  />
  <alias from="view"
         to="(selected layout)"
  />

  <!-- Actions -->
  <action action_id="view"
          category="object"
          condition_expr=""
          title="View"
          url_expr="string:${object_url}"
          visible="True"
          i18n:attributes="title"
  >
    <permission value="View" />
  </action>
  <action action_id="edit"
          category="object"
          condition_expr="not:object/@@plone_lock_info/is_locked_for_current_user|python:True"
          title="Edit"
          url_expr="string:${object_url}/edit"
          visible="True"
          i18n:attributes="title"
  >
    <permission value="Modify portal content" />
  </action>

</object>
