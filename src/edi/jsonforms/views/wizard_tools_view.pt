<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      metal:use-macro="context/@@main_template/macros/master"
      i18n:domain="edi.jsonforms"
>
  <body>
    <metal:block fill-slot="content-core">
      <div class="m-3"
           tal:define="
             json view/jsonschema;
             ui view/uischema;
           "
      >

        <vue-json-form return-data-as-scopes="false"
                       tal:attributes="
                         json-schema json;
                         ui-schema ui;
                       "
        ></vue-json-form>

        <!-- <h4>JSON-Schema</h4>
        <p tal:content="json" />
        <h4>UI-Schema</h4>
        <p tal:content="ui" /> -->
      </div>
    </metal:block>
  </body>
</html>
