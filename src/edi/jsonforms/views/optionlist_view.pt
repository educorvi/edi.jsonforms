<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      metal:use-macro="context/@@main_template/macros/master"
      i18n:domain="edi.jsonforms"
>
  <body>
    <metal:block fill-slot="content-core">

      <form method="post"
            tal:attributes="
              action python: context.absolute_url() + '/@@convert-optionlist-to-options';
            "
      >
        <input name="_authenticator"
               type="hidden"
               tal:attributes="
                 value request/_authenticator;
               "
        />
        <button class="btn btn-primary"
                type="submit"
                i18n:translate=""
        >Convert Option List to Options</button>
        <div class="alert alert-warning mt-3">
          <p i18n:translate="">Warning: This action will convert the Option List into individual Options. This operation cannot be undone.</p>
        </div>
      </form>
    </metal:block>
  </body>
</html>
